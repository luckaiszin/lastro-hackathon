# Chave da API da Anthropic (https://console.anthropic.com/)
# NÃO coloque a chave real aqui — este arquivo é um template versionado.
# Copie para .env (gitignored) e preencha lá.
ANTHROPIC_API_KEY=

# Modelo padrão (rápido/barato). Para síntese final pode-se usar claude-opus-4-8
LLM_MODEL=claude-haiku-4-5-20251001

# Roda o Chromium sem janela (true) ou com janela visível (false, útil p/ anti-bot)
HEADLESS=true

# Ativa a indexação no histórico vetorial (Chroma) durante as buscas
USE_CHROMA=true

# Backend de embeddings da busca semântica:
#   ollama  -> modelo local (requer servidor Ollama + `ollama pull nomic-embed-text`)
#   default -> ONNX embutido no Chroma (sem servidor; bom para testes)
EMBED_BACKEND=ollama
OLLAMA_URL=http://localhost:11434/api/embeddings
OLLAMA_EMBED_MODEL=nomic-embed-text
